STT_PROVIDER=local_whisper
DEFAULT_TRANSCRIPT_MODE=strict_whisper
LOCAL_WHISPER_MODEL=small
LOCAL_WHISPER_DEVICE=auto
LOCAL_WHISPER_COMPUTE_TYPE=int8
LOCAL_WHISPER_LANGUAGE=en
LOCAL_WHISPER_BEAM_SIZE=5

# LLM feedback provider (DeepSeek OpenAI-compatible)
LLM_API_KEY=replace_me
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Optional: keep false to avoid large local mic-audio storage
STORE_ATTEMPT_AUDIO=false
